---
// This frontmatter is intentionally empty.
// The WeatherData interface is defined and used in the client-side script below.
---

<div id="weather" style="text-align: center;">
  <p>Loading weather...</p>
</div>

<script>
  interface WeatherData {
    lat: number;
    lon: number;
    timezone: string;
    timezone_offset: number;
    current: {
      dt: number;
      sunrise: number;
      sunset: number;
      temp: number;
      feels_like: number;
      pressure: number;
      humidity: number;
      dew_point: number;
      uvi: number;
      clouds: number;
      visibility: number;
      wind_speed: number;
      wind_deg: number;
      wind_gust: number;
      weather: {
        id: number;
        main: string;
        description: string;
        icon: string;
      }[];
    };
  }

  async function fetchWeather() {
    const weatherElement = document.getElementById("weather");
    try {
      const response = await fetch("/api/weather");
      if (!response.ok) {
        throw new Error(`Failed to fetch: ${response.statusText}`);
      }
      const data: WeatherData = await response.json();
      const currentWeather = data.current;
      const { lat, lon, timezone, timezone_offset } = data;
      const dt = new Date(currentWeather.dt * 1000).toLocaleString();
      const sunrise = new Date(
        currentWeather.sunrise * 1000
      ).toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
      });
      const sunset = new Date(currentWeather.sunset * 1000).toLocaleTimeString(
        [],
        {
          hour: "2-digit",
          minute: "2-digit",
        }
      );
      const temperature = Math.round(currentWeather.temp);
      const feelsLike = Math.round(currentWeather.feels_like);
      const pressure = currentWeather.pressure;
      const humidity = currentWeather.humidity;
      const dewPoint = currentWeather.dew_point;
      const uvi = currentWeather.uvi;
      const clouds = currentWeather.clouds;
      const visibility = currentWeather.visibility;
      const windSpeed = currentWeather.wind_speed;
      const windDeg = currentWeather.wind_deg;
      const windGust = currentWeather.wind_gust;
      let weatherId = 800;
      let weatherMain = "Clear";
      let weatherDescription = "晴天";
      let weatherIconRaw = "01d";
      let weatherIcon = "01d"; // Use a default icon code
      if (
        Array.isArray(currentWeather.weather) &&
        currentWeather.weather.length > 0 &&
        typeof currentWeather.weather[0] === "object"
      ) {
        weatherId = currentWeather.weather[0].id;
        weatherMain = currentWeather.weather[0].main;
        weatherDescription = currentWeather.weather[0].description;
        weatherIconRaw = currentWeather.weather[0].icon;
        // Validate icon code: should be 2 digits + 'd' or 'n' (e.g. 01d, 02n, 10d, etc.)
        weatherIcon = /^[0-9]{2}[dn]$/.test(weatherIconRaw)
          ? weatherIconRaw
          : "01d";
      }
      const iconUrl = `https://openweathermap.org/img/wn/${weatherIcon}@2x.png`;

      if (weatherElement) {
        weatherElement.innerHTML = ""; // Clear previous contents
        const container = document.createElement("div");
        container.style.textAlign = "center";
        const coordsP = document.createElement("p");
        coordsP.textContent = `Coordinates: ${lat}, ${lon}`;
        container.appendChild(coordsP);
        const timezoneP = document.createElement("p");
        timezoneP.textContent = `Timezone: ${timezone} (UTC+${timezone_offset / 3600})`;
        container.appendChild(timezoneP);
        const updatedP = document.createElement("p");
        updatedP.textContent = `Last updated: ${dt}`;
        container.appendChild(updatedP);
        const mainP = document.createElement("p");
        mainP.style.display = "flex";
        mainP.style.alignItems = "center";
        mainP.style.justifyContent = "center";
        // Weather icon
        const iconImg = document.createElement("img");
        iconImg.src = iconUrl;
        iconImg.alt = weatherDescription;
        iconImg.width = 50;
        iconImg.height = 50;
        mainP.appendChild(iconImg);
        // Weather description and temperature
        const descSpan = document.createElement("span");
        descSpan.textContent = `${temperature}°C, ${weatherDescription}`;
        mainP.appendChild(descSpan);
        container.appendChild(mainP);
        const feelsLikeP = document.createElement("p");
        feelsLikeP.textContent = `Feels like: ${feelsLike}°C`;
        container.appendChild(feelsLikeP);
        const humidityP = document.createElement("p");
        humidityP.textContent = `Humidity: ${humidity}%`;
        container.appendChild(humidityP);
        const dewPointP = document.createElement("p");
        dewPointP.textContent = `Dew Point: ${dewPoint}°C`;
        container.appendChild(dewPointP);
        const uviP = document.createElement("p");
        uviP.textContent = `UV Index: ${uvi}`;
        container.appendChild(uviP);
        const cloudsP = document.createElement("p");
        cloudsP.textContent = `Cloudiness: ${clouds}%`;
        container.appendChild(cloudsP);
        const visibilityP = document.createElement("p");
        visibilityP.textContent = `Visibility: ${visibility}m`;
        container.appendChild(visibilityP);
        const windP = document.createElement("p");
        windP.textContent = `Wind: ${windSpeed} m/s from ${windDeg}°`;
        container.appendChild(windP);
        const windGustP = document.createElement("p");
        windGustP.textContent = `Wind Gust: ${windGust} m/s`;
        container.appendChild(windGustP);
        const pressureP = document.createElement("p");
        pressureP.textContent = `Pressure: ${pressure} hPa`;
        container.appendChild(pressureP);
        const sunriseP = document.createElement("p");
        sunriseP.textContent = `Sunrise: ${sunrise}`;
        container.appendChild(sunriseP);
        const sunsetP = document.createElement("p");
        sunsetP.textContent = `Sunset: ${sunset}`;
        container.appendChild(sunsetP);
        const weatherIdP = document.createElement("p");
        weatherIdP.textContent = `Weather ID: ${weatherId}`;
        container.appendChild(weatherIdP);
        const weatherMainP = document.createElement("p");
        weatherMainP.textContent = `Weather Main: ${weatherMain}`;
        container.appendChild(weatherMainP);
        weatherElement.appendChild(container);
      }
    } catch (error) {
      if (weatherElement) {
        weatherElement.innerHTML =
          "<p>Could not fetch weather. Please check your connection, or try again later.</p>";
      }
      console.error("Failed to fetch weather:", error);
    }
  }

  fetchWeather();
  setInterval(fetchWeather, 600000); // 10 minutes
</script>
