---
// This frontmatter is intentionally empty.
// The WeatherData interface is defined and used in the client-side script below.
---

<div id="weather" style="text-align: center;">
  <p>Loading weather...</p>
</div>

<script>
  interface WeatherData {
    lat: number;
    lon: number;
    timezone: string;
    timezone_offset: number;
    current: {
      dt: number;
      sunrise: number;
      sunset: number;
      temp: number;
      feels_like: number;
      pressure: number;
      humidity: number;
      dew_point: number;
      uvi: number;
      clouds: number;
      visibility: number;
      wind_speed: number;
      wind_deg: number;
      wind_gust: number;
      weather: {
        id: number;
        main: string;
        description: string;
        icon: string;
      }[];
    };
  }

  async function fetchWeather() {
    const weatherElement = document.getElementById("weather");
    try {
      const response = await fetch("/api/weather");
      if (!response.ok) {
        throw new Error(`Failed to fetch: ${response.statusText}`);
      }
      const data: WeatherData = await response.json();
      const currentWeather = data.current;
      const { lat, lon, timezone, timezone_offset } = data;
      const dt = new Date(currentWeather.dt * 1000).toLocaleString();
      const sunrise = new Date(
        currentWeather.sunrise * 1000
      ).toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
      });
      const sunset = new Date(currentWeather.sunset * 1000).toLocaleTimeString(
        [],
        {
          hour: "2-digit",
          minute: "2-digit",
        }
      );
      const temperature = Math.round(currentWeather.temp);
      const feelsLike = Math.round(currentWeather.feels_like);
      const pressure = currentWeather.pressure;
      const humidity = currentWeather.humidity;
      const dewPoint = currentWeather.dew_point;
      const uvi = currentWeather.uvi;
      const clouds = currentWeather.clouds;
      const visibility = currentWeather.visibility;
      const windSpeed = currentWeather.wind_speed;
      const windDeg = currentWeather.wind_deg;
      const wind_gust = currentWeather.wind_gust;
      const weather_id = currentWeather.weather[0].id;
      const weather_main = currentWeather.weather[0].main;
      const weatherDescription = currentWeather.weather[0].description;
      const weatherIcon = currentWeather.weather[0].icon;
      const iconUrl = `https://openweathermap.org/img/wn/${weatherIcon}@2x.png`;

      if (weatherElement) {
        weatherElement.innerHTML = `
          <div style="text-align: center;">
            <p>Coordinates: ${lat}, ${lon}</p>
            <p>Timezone: ${timezone} (UTC+${timezone_offset / 3600})</p>
            <p>Last updated: ${dt}</p>
            <p style="display: flex; align-items: center; justify-content: center;">
              <img src="${iconUrl}" alt="${weatherDescription}" width="50" height="50" />
              <span>${temperature}°C, ${weatherDescription}</span>
            </p>
            <p>Feels like: ${feelsLike}°C</p>
            <p>Humidity: ${humidity}%</p>
            <p>Dew Point: ${dewPoint}°C</p>
            <p>UV Index: ${uvi}</p>
            <p>Cloudiness: ${clouds}%</p>
            <p>Visibility: ${visibility}m</p>
            <p>Wind: ${windSpeed} m/s from ${windDeg}°</p>
            <p>Wind Gust: ${wind_gust} m/s</p>
            <p>Pressure: ${pressure} hPa</p>
            <p>Sunrise: ${sunrise}</p>
            <p>Sunset: ${sunset}</p>
            <p>Weather ID: ${weather_id}</p>
            <p>Weather Main: ${weather_main}</p>
          </div>
        `;
      }
    } catch (error) {
      if (weatherElement) {
        weatherElement.innerHTML = "<p>Could not fetch weather</p>";
      }
      console.error("Failed to fetch weather:", error);
    }
  }

  fetchWeather();
  setInterval(fetchWeather, 600000); // 10 minutes
</script>
